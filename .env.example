# Database
# Ganti sesuai dengan konfigurasi database yang digunakan
DATABASE_URL="postgresql://username:password@localhost:5432/petapetrus"
# Atau untuk MySQL/MariaDB
# DATABASE_URL="mysql://username:password@localhost:3306/petapetrus"
# Atau untuk SQLite
# DATABASE_URL="file:./dev.db"

# Authentication
# Ganti dengan string acak yang panjang untuk keamanan
JWT_SECRET="ganti_dengan_string_random_yang_panjang"
JWT_EXPIRES_IN="7d"

# Application
PUBLIC_APP_URL="http://localhost:5173"
NODE_ENV="development"

# Optional: Logging
LOG_LEVEL="info" 